
# Alpaca Paper Trading (required for order execution)
# ALPACA_API_KEY=your_alpaca_api_key_here
# ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# LLM Model Selection (LiteLLM auto-detects provider from model name)
# Examples: gpt-4.1, claude-sonnet-4-20250514, gemini/gemini-2.5-pro, ollama/llama3
LLM_EVAL_MODEL=gpt-4.1
LLM_SYNTHESIS_MODEL=gpt-4.1

# API Keys (set the key for whichever provider you're using)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Massive (formerly Polygon.io) API key for stock/crypto market data
MASSIVE_API_KEY=

# Substack publishing credentials
SUBSTACK_EMAIL=
SUBSTACK_PASSWORD=
SUBSTACK_PUBLICATION_URL=
# SUBSTACK_COOKIES_PATH is auto-generated by fetch_substack_cookies.py
